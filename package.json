{
  "name": "escuelajs",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint:ts": "eslint \"./src/**/*.{ts,tsx}\" \"./next.config.ts\" --max-warnings 0",
    "lint:ts:fix": "eslint \"./src/**/*.{ts,tsx}\" \"./next.config.ts\" --fix",
    "lint:style": "stylelint \"**/*.{css,scss}\" --config .stylelintrc.cjs",
    "lint:style:fix": "stylelint \"**/*.{css,scss}\" --config .stylelintrc.cjs --fix",
    "lint": "pnpm lint:ts && pnpm lint:style",
    "lint:fix": "pnpm lint:ts:fix && pnpm lint:style:fix",
    "prettier": "prettier --write \"**/*.{ts,tsx,json,css,scss}\"",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,json,css,scss}\"",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "clean": "rimraf .next out build coverage .turbo",
    "clean:full": "pnpm clean && rimraf node_modules",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@apollo/client-integration-nextjs": "^0.14.4",
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "rxjs": "^7.8.2",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@tailwindcss/postcss": "^4",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-use-logical": "^2.1.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "**/*.{css,scss}": [
      "prettier --write",
      "stylelint --fix --config .stylelintrc.cjs"
    ]
  }
}
